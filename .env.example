# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Path to the main log file
LOG_PATH=/path/to/logs/bot.log

# ReadySub login
LOGIN_URL=https://app.readysub.com/account/login
TYLER_EMAIL=your_readysub_email@example.com
TYLER_PASSWORD=your_readysub_password

# Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Gmail SMTP (use an App Password, not your account password)
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFICATION_EMAIL=address_to_receive_notifications@example.com
